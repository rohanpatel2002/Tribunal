# .env.example

# Required: Must be set before running
TRIBUNAL_API_KEY=your_secure_enterprise_api_key_here

# GitHub Integration (Optional)
GITHUB_TOKEN=ghp_your_github_personal_access_token

# LLM Integration (Optional)
OPENROUTER_API_KEY=sk_openrouter_your_api_key

# Frontend Configuration
NEXT_PUBLIC_API_URL=http://localhost:8080

# Database Configuration
DATABASE_URL=postgres://tribunal:tribunal_password_dev@localhost:5432/tribunal_db
POSTGRES_USER=tribunal
POSTGRES_PASSWORD=tribunal_password_dev
POSTGRES_DB=tribunal_db

# Server Configuration
PORT=8080

# Security & CORS
ALLOWED_ORIGINS=http://localhost:3000
GITHUB_WEBHOOK_SECRET=your_webhook_secret_for_github

# Optional: Logging level (debug, info, warn, error)
# LOG_LEVEL=info

# Optional: Enable demo mode for development
# DEMO_MODE=true
