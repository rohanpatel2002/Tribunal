# .env.example

# Required: Must be set before running
TRIBUNAL_API_KEY=your_secure_enterprise_api_key_here

# GitHub Integration (Optional)
GITHUB_TOKEN=ghp_your_github_personal_access_token
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
# GITHUB_OAUTH_REDIRECT_URL=http://localhost:8000/api/v1/github/connect/callback
# GITHUB_OAUTH_SUCCESS_REDIRECT=http://localhost:3000

# LLM Integration (Optional)
OPENROUTER_API_KEY=sk_openrouter_your_api_key

# Frontend Configuration
NEXT_PUBLIC_API_URL=http://localhost:8080
# NEXT_PUBLIC_API_KEY=dev_enterprise_key_123
# DASHBOARD_PORT=3000

# Database Configuration
DATABASE_URL=postgres://tribunal:tribunal_password_dev@localhost:5432/tribunal_db
POSTGRES_USER=tribunal
POSTGRES_PASSWORD=tribunal_password_dev
POSTGRES_DB=tribunal_db

# Redis Configuration (Optional)
REDIS_URL=redis://localhost:6379/0
# REDIS_GITHUB_SESSION_TTL=720h
# REDIS_OAUTH_STATE_TTL=10m

# Monitoring (Optional)
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# Server Configuration
PORT=8080

# Security & CORS
ALLOWED_ORIGINS=http://localhost:3000
GITHUB_WEBHOOK_SECRET=your_webhook_secret_for_github

# Optional: Logging level (debug, info, warn, error)
# LOG_LEVEL=info

# Optional: Enable demo mode for development
# DEMO_MODE=true
