{
  "uid": "tribunal-overview",
  "title": "Tribunal Monitoring Overview",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "timezone": "browser",
  "panels": [
    {
      "type": "stat",
      "title": "Service Up",
      "id": 1,
      "gridPos": {"x": 0, "y": 0, "w": 8, "h": 6},
      "targets": [
        {"refId": "A", "expr": "tribunal_service_up"}
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {"type": "value", "options": {"0": {"text": "Down"}, "1": {"text": "Up"}}}
          ]
        }
      }
    },
    {
      "type": "stat",
      "title": "Redis Errors Total",
      "id": 2,
      "gridPos": {"x": 8, "y": 0, "w": 8, "h": 6},
      "targets": [
        {"refId": "A", "expr": "tribunal_redis_errors_total"}
      ]
    },
    {
      "type": "stat",
      "title": "Redis Ping OK",
      "id": 3,
      "gridPos": {"x": 16, "y": 0, "w": 8, "h": 6},
      "targets": [
        {"refId": "A", "expr": "tribunal_redis_last_ping_ok"}
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {"type": "value", "options": {"0": {"text": "Fail"}, "1": {"text": "OK"}}}
          ]
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Redis Ping Latency (ms)",
      "id": 4,
      "gridPos": {"x": 0, "y": 6, "w": 24, "h": 8},
      "targets": [
        {"refId": "A", "expr": "tribunal_redis_last_ping_latency_ms"}
      ]
    }
  ]
}
